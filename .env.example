# =============================================================================
# Sinal — single-user + UAZAPI + Easypanel
#
# Copie este arquivo para `.env` e preencha os valores. O app le `process.env`
# diretamente, entao carregue no shell antes de rodar localmente:
#
#   set -a && source .env && set +a
#
# =============================================================================

# ── Obrigatorias ──────────────────────────────────────────────────────────────

# Banco principal do app. Em producao no Easypanel, use a URL interna do
# Postgres.
DATABASE_URL=postgres://postgres:password@host:5432/sinal?sslmode=disable

# Porta do servidor Express.
PORT=8080

# Base path do frontend Vite.
BASE_PATH=/

# Dominio publico do app. Usado para montar a URL do webhook da UAZAPI e para o
# script de configuracao automatica do webhook.
PUBLIC_BASE_URL=https://sinal.seudominio.com

# Numero/identificador do dono da conta WhatsApp. O frontend filtra toda
# leitura de mensagens por esse owner.
WHATSAPP_OWNER=5511999999999

# Modo de autenticacao. Por padrao a v1 roda sem login.
AUTH_DISABLED=1

# ── UAZAPI ────────────────────────────────────────────────────────────────────

UAZAPI_BASE_URL=https://lmfotografia.uazapi.com
UAZAPI_INSTANCE_TOKEN=00000000-0000-0000-0000-000000000000

# Como a UAZAPI nao permite configurar header customizado nesse webhook, este
# segredo e enviado na query string:
#   https://seu-dominio/api/webhooks/uazapi?secret=...
UAZAPI_WEBHOOK_SECRET=troque-esse-segredo

# ── Opcional: sessao/local user ───────────────────────────────────────────────

SESSION_SECRET=change-me-to-a-long-random-string
LOCAL_USER_ID=local-user
LOCAL_USER_EMAIL=local@sinal.local

# ── Opcional: frontend local ─────────────────────────────────────────────────

# O dev server do frontend faz proxy de /api para esse alvo.
# API_PROXY_TARGET=http://localhost:8080

# ── Opcional: IA e jobs antigos ───────────────────────────────────────────────

OPENAI_API_KEY=sk-...
# CLASSIFY_PROVIDER=openai
# CLASSIFY_MODEL=
# AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-...
# AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Opcional: Google Contacts ────────────────────────────────────────────────

# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...

# ── Opcional: scheduler/logs ─────────────────────────────────────────────────

# AUTO_REFRESH_DISABLED=1
# AUTO_REFRESH_INTERVAL_MS=21600000
# LOG_LEVEL=info

# ── Opcional: ajustes de jobs ────────────────────────────────────────────────

# SAMPLE_SIZE=
# BATCH_SIZE=
# CONCURRENCY=
# PAGE=
# MAX_MESSAGES=
# MENTION_SAMPLE=
# SCOPE=
# TOPIC_PHRASE_CAP=

# ── Opcional: janela de tempo de resposta ────────────────────────────────────

# RESPONSE_TIME_START_HOUR=9
# RESPONSE_TIME_END_HOUR=18
# RESPONSE_TIME_TZ=America/Sao_Paulo
